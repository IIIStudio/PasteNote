{
  "manifest_version": 3,
  "name": "PasteNote",
  "version": "1.1.0",
  "description": "自托管笔记和知识管理浏览器插件",
  "permissions": [
    "storage",
    "activeTab",
    "sidePanel"
  ],
  "host_permissions": [
    "https://*.tencentcloudapi.com/*",
    "https://*.cos.*.myqcloud.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PasteNote"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}