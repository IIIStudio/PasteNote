{
  "manifest_version": 3,
  "name": "PasteNote",
  "version": "1.2.0",
  "description": "自托管笔记和知识管理浏览器插件",
  "permissions": [
    "storage",
    "activeTab",
    "sidePanel",
    "tabs",
    "contextMenus"
  ],
  "host_permissions": [
    "https://cos.ap-beijing.myqcloud.com/*",
    "https://cos.ap-shanghai.myqcloud.com/*",
    "https://cos.ap-guangzhou.myqcloud.com/*",
    "https://cos.ap-chengdu.myqcloud.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PasteNote"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}